640" w14:textId="77777777" w:rsidR="00FA18AC" w:rsidRDefault="00000000"><w:pPr><w:spacing w:before="120" w:after="60"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="0891B2"/><w:spacing w:val="30"/><w:sz w:val="18"/><w:szCs w:val="18"/></w:rPr><w:t>2</w:t></w:r><w:proofErr w:type="gramStart"/><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="0891B2"/><w:spacing w:val="30"/><w:sz w:val="18"/><w:szCs w:val="18"/></w:rPr><w:t>분  ·</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="0891B2"/><w:spacing w:val="30"/><w:sz w:val="18"/><w:szCs w:val="18"/></w:rPr><w:t xml:space="preserve">  핵심 슬라이드</w:t></w:r></w:p><w:p w14:paraId="4F608708" w14:textId="77777777" w:rsidR="00FA18AC" w:rsidRDefault="00000000"><w:pPr><w:spacing w:after="180" w:line="300" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:i/><w:iCs/><w:color w:val="64748B"/></w:rPr><w:t>이 대본은 예상 질문 5가지를 선제 방어하도록 설계되었습니다. 순서대로 ①왜 자체 학습했는가 ②어떻게 학습했는가 ③어떻게 동작하는가 ④왜 RAVDESS를 포함했는가 ⑤한계는 무엇인가에 대한 답이 자연스럽게 포함됩니다.</w:t></w:r></w:p><w:p w14:paraId="45291952" w14:textId="77777777" w:rsidR="00FA18AC" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="3"/></w:pPr><w:r><w:t>대본</w:t></w:r></w:p><w:p w14:paraId="71B10DD8" w14:textId="1D1E64E2" w:rsidR="00205C88" w:rsidRDefault="00000000" w:rsidP="007D4AF4"><w:pPr><w:pBdr><w:left w:val="single" w:sz="24" w:space="10" w:color="3160D8"/></w:pBdr><w:spacing w:before="100" w:after="140" w:line="340" w:lineRule="auto"/><w:ind w:left="360"/></w:pPr><w:r><w:t xml:space="preserve">이어서 </w:t></w:r><w:r w:rsidR="00205C88"><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>현재</w:t></w:r><w:r w:rsidR="00205C88"><w:t xml:space="preserve"> 시스템의 한계와 확장 방향입니다.</w:t></w:r></w:p><w:p w14:paraId="306D089D" w14:textId="77777777" w:rsidR="00205C88" w:rsidRDefault="00205C88" w:rsidP="00205C88"><w:pPr><w:pBdr><w:left w:val="single" w:sz="24" w:space="10" w:color="3160D8"/></w:pBdr><w:spacing w:before="100" w:after="140" w:line="340" w:lineRule="auto"/><w:ind w:left="360"/></w:pPr><w:r><w:t xml:space="preserve">end-to-end로 동작은 하지만, 병목이 두 가지 있습니다. 레퍼런스 음성 선택이 수동이라는 점, 그리고 TTS 출력 품질을 자동으로 검증할 장치가 없어 </w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:t>저품질</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:t xml:space="preserve"> 구간이 결과물에 그대로 </w:t></w:r><w:r><w:lastRenderedPageBreak/><w:t>반영된다는 점입니다.</w:t></w:r></w:p><w:p w14:paraId="61F02D4C" w14:textId="77777777" w:rsidR="00205C88" w:rsidRDefault="00205C88" w:rsidP="00205C88"><w:pPr><w:pBdr><w:left w:val="single" w:sz="24" w:space="10" w:color="3160D8"/></w:pBdr><w:spacing w:before="100" w:after="140" w:line="340" w:lineRule="auto"/><w:ind w:left="360"/></w:pPr><w:r><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>이를</w:t></w:r><w:r><w:t xml:space="preserve"> 해결하기 위해 자체 MOS 예측 모델을 학습시켰습니다. MOS는 음성 자연스러움을 1점에서 5점으로 평가하는 지표인데, 기존 공개 모델들은 중립 음성 중심으로 학습되어 감정이 실린 구간에서 편향이 발생합니다. 저희는 wav2vec2-base 위에 MLP 헤드를 얹고, TTS 벤치마크인 BVCC에 감정 음성 데이터셋 RAVDESS를 결합하여 학습했습니다. 감정 강도별로 차등 기준 점수를 부여해서, TTS가 감정을 죽이는 방향으로 수렴하는 것을 방지했습</w:t></w:r><w:r><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>니다</w:t></w:r><w:r><w:t>.</w:t></w:r></w:p><w:p w14:paraId="02D3AE35" w14:textId="5606BAA3" w:rsidR="00205C88" w:rsidRDefault="00205C88" w:rsidP="00205C88"><w:pPr><w:pBdr><w:left w:val="single" w:sz="24" w:space="10" w:color="3160D8"/></w:pBdr><w:spacing w:before="100" w:after="140" w:line="340" w:lineRule="auto"/><w:ind w:left="360"/></w:pPr><w:r><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>이</w:t></w:r><w:r><w:t xml:space="preserve"> 모델은 두 지점에서 동작합니다. 레퍼런스 자동 선택에서 최고 품질 구간을 채택하고, 합성 점수가 3.5 미만이면 자동 재합성을 </w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:t>트리거합니다</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:t>. 한계로는 MOS가 음질 중심이라 감정 정확도는 별도 지표가 필요하며, 이 부분은 emotion2vec 기반 이중 평가 구조로 보완할 계획입니다.</w:t></w:r></w:p><w:p w14:paraId="01928CAC" w14:textId="77777777" w:rsidR="00FA18AC" w:rsidRDefault="00000000"><w:pPr><w:spacing w:before="80" w:after="120"/><w:ind w:left="240"/></w:pPr><w:r><w:t xml:space="preserve">💡 </w:t></w:r><w:r><w:rPr><w:i/><w:iCs/><w:color w:val="64748B"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t>전체 흐름: 문제 제기 → 자체 학습 이유 → 모델 구조 → 학습 데이터 설계 의도 → 운영 방식 → 한계·보완 계획. 이 순서로 가면 교수님이 질문할 만한 틈이 거의 없음. 특히 RAVDESS 결합 이유(감정 평탄화 방지) 부분이 핵심 방어 포인트.</w:t></w:r></w:p><w:p w14:paraId="6E2B5DD3" w14:textId="77777777" w:rsidR="00FA18AC" w:rsidRDefault="00000000"><w:pPr><w:spacing w:before="80" w:after="120"/><w:ind w:left="240"/></w:pPr><w:r><w:t xml:space="preserve">💡 </w:t></w:r><w:r><w:rPr><w:i/><w:iCs/><w:color w:val="64748B"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t>발음 주의: BVCC (</w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:rPr><w:i/><w:iCs/><w:color w:val="64748B"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t>비브이씨씨</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:rPr><w:i/><w:iCs/><w:color w:val="64748B"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t>), RAVDESS (</w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:rPr><w:i/><w:iCs/><w:color w:val="64748B"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t>라브데스</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:rPr><w:i/><w:iCs/><w:color w:val="64748B"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t>), wav2vec2-base (</w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:rPr><w:i/><w:iCs/><w:color w:val="64748B"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t>웨이브투벡</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:rPr><w:i/><w:iCs/><w:color w:val="64748B"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t>-투-베이스), self-supervised (셀프-</w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:rPr><w:i/><w:iCs/><w:color w:val="64748B"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t>슈퍼바이즈드</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:rPr><w:i/><w:iCs/><w:color w:val="64748B"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t>)</w:t></w:r></w:p><w:p w14:paraId="10BB6277" w14:textId="77777777" w:rsidR="00FA18AC" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="2"/></w:pPr><w:r><w:t xml:space="preserve">Slide 11 — 08 향후 계획 및 </w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:t>간트차트</w:t></w:r><w:proofErr w:type="spellEnd"/></w:p><w:p w14:paraId="7FBD2327" w14:textId="77777777" w:rsidR="00FA18AC" w:rsidRDefault="00000000"><w:pPr><w:spacing w:before="120" w:after="60"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="0891B2"/><w:spacing w:val="30"/><w:sz w:val="18"/><w:szCs w:val="18"/></w:rPr><w:t>30초</w:t></w:r></w:p><w:p w14:paraId="15FA8AA7" w14:textId="77777777" w:rsidR="00FA18AC" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="3"/></w:pPr><w:r><w:t>대본</w:t></w:r></w:p><w:p w14:paraId="47A5E955" w14:textId="672A6D85" w:rsidR="00FA18AC" w:rsidRDefault="00000000"><w:pPr><w:pBdr><w:left w:val="single" w:sz="24" w:space="10" w:color="3160D8"/></w:pBdr><w:spacing w:before="100" w:after="140" w:line="340" w:lineRule="auto"/><w:ind w:left="360"/></w:pPr><w:r><w:t xml:space="preserve">마지막으로 향후 계획입니다. 중간발표 이후 약 </w:t></w:r><w:r w:rsidR="002529C7"><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>7</w:t></w:r><w:r><w:t>주간 모델 고도화, UI 개발, 최종발표 준비를 병렬로 진행합니다. 현재 7주차에는 데이터셋 확보와 모델 성능 향상을 진행 중이며, 8주차에 VAD와 화자 분리 개선, 9주차에 파이프라인 최적화와 UI 구현, 11주차에 중간발표2, 13주차에 최종발표를 계획하고 있습니다.</w:t></w:r></w:p><w:p w14:paraId="42F5325A" w14:textId="77777777" w:rsidR="00FA18AC" w:rsidRDefault="00000000"><w:pPr><w:pBdr><w:left w:val="single" w:sz="24" w:space="10" w:color="3160D8"/></w:pBdr><w:spacing w:before="100" w:after="140" w:line="340" w:lineRule="auto"/><w:ind w:left="360"/></w:pPr><w:r><w:lastRenderedPageBreak/><w:t>이상으로 발표를 마치겠습니다. 감사합니다.</w:t></w:r></w:p><w:p w14:paraId="539983AE" w14:textId="77777777" w:rsidR="00FA18AC" w:rsidRDefault="00000000"><w:pPr><w:spacing w:before="80" w:after="120"/><w:ind w:left="240"/></w:pPr><w:r><w:t xml:space="preserve">💡 </w:t></w:r><w:r><w:rPr><w:i/><w:iCs/><w:color w:val="64748B"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t>마지막 '감사합니다' 전 잠시 호흡을 두고 청중 전체를 한 번 훑어보기. 긴장 풀지 말고 Q&amp;A 대비 자세 유지.</w:t></w:r></w:p><w:p w14:paraId="435D9403" w14:textId="34A6CE18" w:rsidR="00FA18AC" w:rsidRDefault="00FA18AC"/><w:sectPr w:rsidR="00FA18AC"><w:pgSz w:w="12240" w:h="15840"/><w:pgMar w:top="1440" w:right="1440" w:bottom="1440" w:left="1440" w:header="708" w:footer="708" w:gutter="0"/><w:cols w:space="720"/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>