# ─────────────────────────────────────────────────────────────
# AI Dubbing System — 환경변수 템플릿
# 실제 사용 시 본 파일을 복사: cp .env.example .env
# .env 는 .gitignore 처리되어 repo 에 올라가지 않습니다.
# ─────────────────────────────────────────────────────────────

# HuggingFace token (모델 다운로드용)
# https://huggingface.co/settings/tokens 에서 발급
HF_TOKEN=YOUR_HF_TOKEN_HERE

# LLM API key (영-한 번역, GPT 5.4 호출용)
# 본인 LLM provider의 API key 입력
VECTORENGINE_API_KEY=YOUR_LLM_API_KEY_HERE
